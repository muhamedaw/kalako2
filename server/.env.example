# Port the Node process listens on (nginx reverse-proxies to this)
PORT=4001

# Public base URL used to build join links / QR codes, e.g. https://kalak-16-16-218-187.sslip.io
JOIN_BASE_URL=http://localhost:4001

# Absolute or relative path to the SQLite file (game history archive)
DB_PATH=./data/kalak.sqlite

# Socket.io / Express CORS origin. Restrict this in production.
CORS_ORIGIN=*

# Milliseconds a disconnected player's seat is held before being removed (30s)
RECONNECT_WINDOW_MS=30000

# Seconds a voting round waits before auto-resolving (answer time is set per-room by the host)
VOTE_TIME_SECONDS=30

# Shortened timer used for TIEBREAKER rounds
TIEBREAKER_TIME_SECONDS=15
